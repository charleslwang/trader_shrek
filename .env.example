# Alpaca API Configuration
ALPACA_API_KEY=replace_me
ALPACA_SECRET_KEY=replace_me
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Shrek Mode
# Options: dry-run, paper
# live mode is explicitly disabled and will cause an error
SHREK_MODE=paper

# Configuration File
SHREK_CONFIG=config/shrek.paper.yaml

# LLM Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# SEC EDGAR Configuration
# Must include your contact information for SEC compliance
SEC_USER_AGENT="shrek-research/0.1 [contact@example.com]"

# Rust Logging
RUST_LOG=info
